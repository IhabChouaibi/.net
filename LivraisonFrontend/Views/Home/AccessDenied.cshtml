@using LivraisonFrontend.Helpers
@inject SessionManager SessionManager
@{
    ViewData["Title"] = "Accès refusé";
    var targetController = SessionManager.IsAdmin ? "Dashboard" : SessionManager.IsUser ? "ClientHome" : "Auth";
    var targetAction = SessionManager.HasActiveSession ? "Index" : "Login";
}

<section class="surface-panel error-panel">
    <div class="error-icon"><i class="bi bi-shield-lock"></i></div>
    <p class="eyebrow mb-2">Accès refusé</p>
    <h1 class="section-title mb-3">Cette page n'est pas accessible avec votre rôle.</h1>
    <p class="text-muted mb-4">Les pages administrateur sont réservées au rôle Admin. Les pages client sont réservées au rôle User.</p>
    <a asp-controller="@targetController" asp-action="@targetAction" class="btn btn-primary">
        <i class="bi bi-arrow-left me-2"></i>Retour
    </a>
</section>
