@model AccountModel

<section class="surface-panel">
    <div class="panel-header"><div><p class="eyebrow mb-1">Administration</p><h2 class="section-title">Modifier le compte</h2></div></div>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <input asp-for="Id" type="hidden" />
        <div class="col-md-6"><label asp-for="Nom" class="form-label"></label><input asp-for="Nom" class="form-control" /><span asp-validation-for="Nom" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="Prenom" class="form-label"></label><input asp-for="Prenom" class="form-control" /><span asp-validation-for="Prenom" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="Telephone" class="form-label"></label><input asp-for="Telephone" class="form-control" /><span asp-validation-for="Telephone" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="CIN" class="form-label"></label><input asp-for="CIN" class="form-control" /><span asp-validation-for="CIN" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="Login" class="form-label"></label><input asp-for="Login" class="form-control" /><span asp-validation-for="Login" class="text-danger small"></span></div>
        <div class="col-12"><label asp-for="Adresse" class="form-label"></label><input asp-for="Adresse" class="form-control" /><span asp-validation-for="Adresse" class="text-danger small"></span></div>
        <div class="col-md-4"><label asp-for="Ville" class="form-label"></label><input asp-for="Ville" class="form-control" /><span asp-validation-for="Ville" class="text-danger small"></span></div>
        <div class="col-md-4"><label asp-for="CodePostal" class="form-label"></label><input asp-for="CodePostal" class="form-control" /><span asp-validation-for="CodePostal" class="text-danger small"></span></div>
        <div class="col-md-4"><label asp-for="Role" class="form-label"></label><select asp-for="Role" class="form-select"><option value="Admin">Admin</option><option value="User">User</option></select></div>
        <div class="col-12"><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control" placeholder="Laisser vide pour ne pas modifier" /><span asp-validation-for="Password" class="text-danger small"></span></div>
        <div class="col-12 d-flex gap-2"><button type="submit" class="btn btn-primary">Mettre à jour</button><a asp-action="Index" class="btn btn-outline-secondary">Annuler</a></div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
