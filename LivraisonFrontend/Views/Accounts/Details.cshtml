@model AccountModel

<section class="surface-panel">
    <div class="panel-header"><div><p class="eyebrow mb-1">Administration</p><h2 class="section-title">Détails du compte</h2></div></div>
    <dl class="details-grid">
        <div><dt>Id</dt><dd>@Model.Id</dd></div>
        <div><dt>Nom</dt><dd>@Model.Nom</dd></div>
        <div><dt>Prénom</dt><dd>@Model.Prenom</dd></div>
        <div><dt>Login</dt><dd>@Model.Login</dd></div>
        <div><dt>Email</dt><dd>@Model.Email</dd></div>
        <div><dt>Téléphone</dt><dd>@Model.Telephone</dd></div>
        <div><dt>CIN</dt><dd>@Model.CIN</dd></div>
        <div><dt>Adresse</dt><dd>@Model.Adresse</dd></div>
        <div><dt>Ville</dt><dd>@Model.Ville</dd></div>
        <div><dt>Code postal</dt><dd>@Model.CodePostal</dd></div>
        <div><dt>Rôle</dt><dd><partial name="_StatusBadge" model="Model.Role" /></dd></div>
    </dl>
    <div class="d-flex gap-2 mt-4"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a><a asp-action="Index" class="btn btn-outline-secondary">Retour</a></div>
</section>
