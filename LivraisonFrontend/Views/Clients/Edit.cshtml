@model ClientModel

<section class="surface-panel">
    <div class="panel-header">
        <div>
            <p class="eyebrow mb-1">Mise à jour</p>
            <h2 class="section-title">Modifier le client</h2>
        </div>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <input asp-for="Id" type="hidden" />
        <partial name="_Form" model="Model" />
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Mettre à jour</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
