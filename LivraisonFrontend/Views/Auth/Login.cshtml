@model LoginViewModel

<section class="auth-page auth-page-login">
    <div class="auth-showcase">
        <p class="eyebrow text-white-50">Client & Admin Access</p>
        <h1 class="auth-hero-title">Accédez à votre espace livraison avec une session stable et un suivi clair.</h1>
        <p class="auth-hero-copy">
            Les administrateurs pilotent la plateforme. Les utilisateurs suivent leurs colis, leur profil et leurs livraisons.
        </p>
        <div class="auth-stat-grid">
            <div class="auth-stat-card"><strong>Session</strong><span>JWT stocké en session</span></div>
            <div class="auth-stat-card"><strong>Tracking</strong><span>Timeline colis</span></div>
            <div class="auth-stat-card"><strong>Accès</strong><span>Admin et User uniquement</span></div>
        </div>
    </div>

    <div class="auth-card-panel surface-panel">
        <div class="mb-4">
            <p class="eyebrow mb-2">Connexion</p>
            <h2 class="section-title mb-2">Se connecter</h2>
            <p class="text-muted mb-0">Utilisez votre login et votre mot de passe pour accéder à votre espace.</p>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="col-12">
                <label asp-for="Login" class="form-label"></label>
                <input asp-for="Login" class="form-control form-control-lg" placeholder="Votre login" />
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control form-control-lg" placeholder="Votre mot de passe" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="col-12 d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </button>
            </div>

            <div class="col-12 text-center">
                <a asp-action="Register" class="auth-link">Créer un compte client</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
