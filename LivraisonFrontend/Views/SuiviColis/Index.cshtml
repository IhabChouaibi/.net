@model LivraisonFrontend.ViewModels.SuiviColisPageViewModel

<section class="surface-panel tracking-hero">
    <div>
        <p class="eyebrow mb-2">Suivi client</p>
        <h2 class="section-title mb-2">@Model.Title</h2>
        <p class="text-muted mb-0">@Model.Subtitle</p>
    </div>
</section>

<section class="surface-panel mt-3">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-4">
            <label asp-for="Filters.SearchTerm" class="form-label"></label>
            <input asp-for="Filters.SearchTerm" class="form-control" placeholder="Id, libellé ou statut" />
        </div>
        <div class="col-md-3 col-lg-2">
            <label asp-for="Filters.Status" class="form-label"></label>
            <select asp-for="Filters.Status" class="form-select">
                <option value="">Tous</option>
                <option value="En attente">En attente</option>
                <option value="En cours">En cours</option>
                <option value="Livré">Livré</option>
                <option value="Annulé">Annulé</option>
            </select>
        </div>
        <div class="col-md-3 col-lg-2">
            <label asp-for="Filters.Ville" class="form-label"></label>
            <input asp-for="Filters.Ville" class="form-control" placeholder="Ville" />
        </div>
        <div class="col-md-3 col-lg-2">
            <label asp-for="Filters.DateLivraison" class="form-label"></label>
            <input asp-for="Filters.DateLivraison" class="form-control" />
        </div>
        <div class="col-md-3 col-lg-2 d-grid">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Rechercher
            </button>
        </div>
    </form>
</section>

<section class="tracking-grid mt-3">
    @if (Model.Items.Any())
    {
        @foreach (var item in Model.Items)
        {
            <article class="surface-panel tracking-card">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <p class="eyebrow mb-2">Colis #@item.Id</p>
                        <h3 class="tracking-card-title">@item.Libelle</h3>
                        <p class="tracking-meta mb-0">@item.Ville · @item.DateLivraison:dd/MM/yyyy</p>
                    </div>
                    <partial name="_StatusBadge" model="item.Statut" />
                </div>

                <div class="tracking-timeline">
                    @{
                        var steps = new[] { "En attente", "En cours", "Livré", "Annulé" };
                    }
                    @foreach (var step in steps)
                    {
                        var isActive = string.Equals(item.Statut, step, StringComparison.OrdinalIgnoreCase);
                        <div class="timeline-step @(isActive ? "active" : "") @(step == "Annulé" && isActive ? "danger" : "")">
                            <span class="timeline-dot"></span>
                            <span>@step</span>
                        </div>
                    }
                </div>

                <div class="tracking-details-grid">
                    <div><span>Montant</span><strong>@item.Montant.ToString("0.00") TND</strong></div>
                    <div><span>Poids</span><strong>@item.Poids.ToString("0.##") kg</strong></div>
                    <div><span>Volume</span><strong>@item.Volume.ToString("0.###") m³</strong></div>
                    <div><span>Adresse</span><strong>@item.Adresse</strong></div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">
                        <i class="bi bi-eye me-2"></i>Détails
                    </a>
                </div>
            </article>
        }
    }
    else
    {
        <div class="surface-panel empty-state-panel">
            <i class="bi bi-inboxes empty-state-icon"></i>
            <h3>Aucun colis trouvé</h3>
            <p class="text-muted mb-0">Ajustez vos filtres ou vérifiez que votre compte client est bien lié à des colis.</p>
        </div>
    }
</section>
