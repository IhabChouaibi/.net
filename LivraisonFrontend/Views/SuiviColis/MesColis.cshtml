@model LivraisonFrontend.ViewModels.SuiviColisPageViewModel

<section class="surface-panel">
    <div class="panel-header flex-wrap gap-3">
        <div>
            <p class="eyebrow mb-1">Mes colis</p>
            <h2 class="section-title">@Model.Title</h2>
            <p class="text-muted mb-0">@Model.Subtitle</p>
        </div>
    </div>

    <form method="get" class="row g-3 filter-bar">
        <div class="col-md-4">
            <input asp-for="Filters.SearchTerm" class="form-control" placeholder="Id colis, libellé ou statut" />
        </div>
        <div class="col-md-3">
            <input asp-for="Filters.Ville" class="form-control" placeholder="Ville" />
        </div>
        <div class="col-md-3">
            <input asp-for="Filters.DateLivraison" class="form-control" />
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-search me-2"></i>Filtrer
            </button>
        </div>
    </form>

    @if (Model.Items.Any())
    {
        <div class="table-responsive mt-3">
            <table class="table premium-table align-middle mb-0">
                <thead>
                <tr>
                    <th>Colis</th>
                    <th>Ville</th>
                    <th>Date livraison</th>
                    <th>Montant</th>
                    <th>Statut</th>
                    <th class="text-end">Détails</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><strong>#@item.Id</strong><div class="text-muted small">@item.Libelle</div></td>
                        <td>@item.Ville</td>
                        <td>@item.DateLivraison:dd/MM/yyyy</td>
                        <td>@item.Montant.ToString("0.00") TND</td>
                        <td><partial name="_StatusBadge" model="item.Statut" /></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-inline-state mt-3">
            <i class="bi bi-inboxes"></i>
            <div>
                <strong>Aucun colis disponible pour le moment</strong>
                <p class="text-muted mb-0">@Model.EmptyDescription</p>
            </div>
        </div>
    }
</section>
