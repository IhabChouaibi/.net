@model LivraisonFrontend.ViewModels.SuiviColisPageViewModel

<section class="surface-panel">
    <div class="panel-header flex-wrap gap-3">
        <div>
            <p class="eyebrow mb-1">Mes colis</p>
            <h2 class="section-title">@Model.Title</h2>
        </div>
    </div>

    <form method="get" class="row g-3 filter-bar">
        <div class="col-md-4"><input asp-for="Filters.SearchTerm" class="form-control" placeholder="Id, libellé ou statut" /></div>
        <div class="col-md-3"><input asp-for="Filters.Ville" class="form-control" placeholder="Ville" /></div>
        <div class="col-md-3"><input asp-for="Filters.DateLivraison" class="form-control" /></div>
        <div class="col-md-2 d-grid"><button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-2"></i>Filtrer</button></div>
    </form>

    <div class="table-responsive mt-3">
        <table class="table premium-table align-middle mb-0">
            <thead>
            <tr>
                <th>Colis</th>
                <th>Ville</th>
                <th>Date livraison</th>
                <th>Montant</th>
                <th>Statut</th>
                <th class="text-end">Détails</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Any())
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><strong>#@item.Id</strong><div class="text-muted small">@item.Libelle</div></td>
                        <td>@item.Ville</td>
                        <td>@item.DateLivraison:dd/MM/yyyy</td>
                        <td>@item.Montant.ToString("0.00") TND</td>
                        <td><partial name="_StatusBadge" model="item.Statut" /></td>
                        <td class="text-end"><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted py-4">Aucun colis disponible.</td></tr>
            }
            </tbody>
        </table>
    </div>
</section>
