@model LivreurModel

<section class="surface-panel">
    <div class="panel-header">
        <div>
            <p class="eyebrow mb-1">Consultation</p>
            <h2 class="section-title">Détails du livreur</h2>
        </div>
    </div>

    <dl class="details-grid">
        <div><dt>Id</dt><dd>@Model.Id</dd></div>
        <div><dt>CIN</dt><dd>@Model.CIN</dd></div>
        <div><dt>Raison sociale</dt><dd>@Model.RaisonSocial</dd></div>
        <div><dt>Ville</dt><dd>@Model.Ville</dd></div>
        <div><dt>Code postal</dt><dd>@Model.CodePostal</dd></div>
    </dl>

    <div class="d-flex gap-2 mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Modifier</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Retour</a>
    </div>
</section>
