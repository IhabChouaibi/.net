@model ColisModel

<section class="surface-panel">
    <div class="panel-header">
        <div>
            <p class="eyebrow mb-1">Création</p>
            <h2 class="section-title">Nouveau colis</h2>
        </div>
    </div>

    <form asp-action="Create" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <partial name="_Form" model="Model" />
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
