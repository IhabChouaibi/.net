@model LivraisonFrontend.ViewModels.CreateColisViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Colis.Libelle" class="form-label"></label>
        <input asp-for="Colis.Libelle" class="form-control" placeholder="Libellé du colis" />
        <span asp-validation-for="Colis.Libelle" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Colis.DateLivraison" class="form-label"></label>
        <input asp-for="Colis.DateLivraison" type="date" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Colis.ClientId" class="form-label"></label>
        <select asp-for="Colis.ClientId" asp-items="Model.ListeClients" class="form-select select2-premium" data-placeholder="Sélectionner un client">
            <option value="">Sélectionner un client</option>
        </select>
        <span asp-validation-for="Colis.ClientId" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Colis.LivreurId" class="form-label"></label>
        <select asp-for="Colis.LivreurId" asp-items="Model.ListeLivreurs" class="form-select select2-premium" data-placeholder="Sélectionner un livreur">
            <option value="">Sélectionner un livreur</option>
        </select>
        <span asp-validation-for="Colis.LivreurId" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Colis.Montant" class="form-label"></label>
        <input asp-for="Colis.Montant" class="form-control" placeholder="0.00" />
    </div>
    <div class="col-md-4">
        <label asp-for="Colis.Poids" class="form-label"></label>
        <input asp-for="Colis.Poids" class="form-control" placeholder="0.00" />
    </div>
    <div class="col-md-4">
        <label asp-for="Colis.Volume" class="form-label"></label>
        <input asp-for="Colis.Volume" class="form-control" placeholder="0.000" />
    </div>
    <div class="col-md-6">
        <label asp-for="Colis.StatutLivraisonId" class="form-label"></label>
        <select asp-for="Colis.StatutLivraisonId" class="form-select">
            <option value="1">En attente</option>
            <option value="2">En cours</option>
            <option value="3">Livré</option>
            <option value="4">Annulé</option>
        </select>
    </div>
</div>
