@model ColisModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Libelle" class="form-label"></label>
        <input asp-for="Libelle" class="form-control" placeholder="Libellé du colis" />
        <span asp-validation-for="Libelle" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DateLivraison" class="form-label"></label>
        <input asp-for="DateLivraison" type="date" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ClientId" class="form-label"></label>
        <input asp-for="ClientId" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="LivreurId" class="form-label"></label>
        <input asp-for="LivreurId" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Montant" class="form-label"></label>
        <input asp-for="Montant" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Poids" class="form-label"></label>
        <input asp-for="Poids" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Volume" class="form-label"></label>
        <input asp-for="Volume" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="StatutLivraisonId" class="form-label"></label>
        <select asp-for="StatutLivraisonId" class="form-select">
            <option value="1">En attente</option>
            <option value="2">En cours</option>
            <option value="3">Livré</option>
            <option value="4">Annulé</option>
        </select>
    </div>
</div>
